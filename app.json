{
  "expo": {
    "name": "Kribb - Property Listings App",
    "slug": "kribb",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/kribb.png",
    "scheme": "propertylistingapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kribb.app",
      "versionCode": 3,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Kribb to access your location to tag property coordinates."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/kribb.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "privacyPolicyUrl": "https://www.termsfeed.com/live/a41c7447-ff69-43e9-b2c6-1caf1409c478",
      "router": {},
      "eas": {
        "projectId": "4974f115-8e72-4a9e-bc21-965917564b91"
      }
    }
  }
}
